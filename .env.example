# Required local values
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WaxWatchLocal
NEXT_PUBLIC_RELEASE_VERSION=dev-local
SESSION_COOKIE_NAME=waxwatch_session
TRUSTED_PROXY_CIDRS=127.0.0.1/32
LOG_LEVEL=debug

# Required keys that can use placeholders in local dev
NEXT_PUBLIC_SENTRY_DSN=https://public@example.invalid/1
SENTRY_DSN=https://secret@example.invalid/1
AWS_REGION=local
AWS_SECRETS_PREFIX=/waxwatch/local/web
