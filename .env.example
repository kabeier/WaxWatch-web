# Runtime contract keys (must stay in sync with src/config/env.ts)
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Placeholder/local sample. Production must use your real public app name (no "local" marker).
NEXT_PUBLIC_APP_NAME=WaxWatch (Local)

# Placeholder/local sample. Production must use an actual release identifier (no "local"/"development" values).
NEXT_PUBLIC_RELEASE_VERSION=local-dev

# Placeholder Sentry DSN for local/dev only. Production must use a real DSN and remove template-like tokens.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional; can be a URL or same-origin relative path.
NEXT_PUBLIC_API_BASE_URL=/api

# Placeholder Sentry DSN for local/dev only. Production must use a real DSN and remove template-like tokens.
SENTRY_DSN=https://exampleSecretKey@o0.ingest.sentry.io/0

AWS_REGION=us-east-1

# Local default prefix for development. Production must replace with the production secret namespace (not local/default).
AWS_SECRETS_PREFIX=/waxwatch/local/web

SESSION_COOKIE_NAME=waxwatch_session

# Local-only sample. Production must include real upstream/proxy CIDRs and must not be loopback-only.
TRUSTED_PROXY_CIDRS=127.0.0.1/32

LOG_LEVEL=debug
