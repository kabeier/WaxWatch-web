{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["src/*"],
      "@api-core/*": ["src/lib/api/*"],
      "@web-query/*": ["src/lib/query/*"]
    }
  },
  "include": ["next-env.d.ts", "pages/**/*", "app/**/*", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
